# ── Production environment variables for Vercel ─────────────────────────────
# Copy to Vercel project settings → Environment Variables.
# Never commit real secrets to git.

# ── Resend (transactional email for the reservation form) ───────────────────
# Sign up at https://resend.com, verify the domain littleloutra.com (DNS records),
# then create an API key.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mailbox that receives reservation requests.
RESERVATION_TO_EMAIL=stay@littleloutra.com

# Verified sender (must be an address on a Resend-verified domain).
RESERVATION_FROM=Little Loutra <stay@littleloutra.com>

# ── Cloudflare Turnstile (captcha, anti-bot) ───────────────────────────────
# Sign up at https://dash.cloudflare.com/?to=/:account/turnstile, add littleloutra.com
# and copy both the site key (public) and the secret key (server).
#
# The site key is embedded in the built JS bundle — set it in Vercel so Vite
# picks it up at build time. It must be prefixed with VITE_.
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxx

# Secret key — server-side only (used by /api/reserve to verify tokens).
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxxxxxxxxxxxxxx
